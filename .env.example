# App
APP_ENV=local
DATABASE_URL=sqlite:///./data/grammar_agent.db
TIMEZONE=Asia/Shanghai
DAILY_LESSON_HOUR=7
DAILY_LESSON_MINUTE=30
DEFAULT_USER_ID=local-user

# LLM
# openai uses Responses API. deepseek uses OpenAI-compatible Chat Completions.
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4.1-mini

# Backward-compatible OpenAI variables. Used when LLM_* is empty.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Feishu self-built app
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_DEFAULT_RECEIVE_ID=
