# Copy this file to /opt/grammar-agent/.env on the server.

APP_ENV=production
DATABASE_URL=sqlite:////opt/grammar-agent/data/grammar_agent.db
TIMEZONE=Asia/Shanghai
DAILY_LESSON_HOUR=7
DAILY_LESSON_MINUTE=30
DEFAULT_USER_ID=local-user

# OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4.1-mini

# DeepSeek
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_DEFAULT_RECEIVE_ID=
